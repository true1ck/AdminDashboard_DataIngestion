generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Archetype {
  id           String        @id @default(uuid())
  archetypeKey String        @unique
  name         String
  icon         String
  tagline      String
  primaryColor String
  kpis         Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  constituency Constituency?
  pillarScores PillarScore?
  sansadRecord SansadRecord?
}

model Constituency {
  id           String    @id @default(uuid())
  name         String
  party        String
  state        String
  type         String
  electionDate String
  totalBooths  Int
  archetypeId  String    @unique
  archetype    Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
}

model PillarScore {
  id                      String    @id @default(uuid())
  archetypeId             String    @unique
  electoralStrength       Int       @default(50)
  legislativePerformance  Int       @default(50)
  constituencyDevelopment Int       @default(50)
  publicAccessibility     Int       @default(50)
  communication           Int       @default(50)
  partyStanding           Int       @default(50)
  mediaCoverage           Int       @default(50)
  digitalInfluence        Int       @default(50)
  financialMuscle         Int       @default(50)
  allianceIntel           Int       @default(50)
  casteEquation           Int       @default(50)
  antiIncumbency          Int       @default(50)
  grassrootsNetwork       Int       @default(50)
  ideologyConsistency     Int       @default(50)
  scandalIndex            Int       @default(50)
  archetype               Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
}

model SansadRecord {
  id                   String    @id @default(uuid())
  archetypeId          String    @unique
  attendancePercentage Int
  questionsAsked       Int
  privateBills         Int
  billsPassed          Int
  archetype            Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
}

model Rival {
  id        String   @id @default(uuid())
  name      String
  nriScore  Float
  trend     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(uuid())
  text      String
  source    String
  sentiment Float
  emotion   String
  pillarId  String
  urgency   String
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
}

model SocialItem {
  id        String   @id @default(uuid())
  platform  String
  author    String
  text      String
  sentiment Float
  emotion   String
  likes     Int      @default(0)
  reposts   Int      @default(0)
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
}

model Alert {
  id              String       @id @default(uuid())
  severity        String
  title           String
  description     String
  aiSuggestedText String
  aiConfidence    Float
  icon            String
  isDispatched    Boolean      @default(false)
  timestamp       DateTime     @default(now())
  iasclAction     IASCLAction?
}

model IASCLAction {
  id            String            @id @default(uuid())
  uid           String            @unique
  status        String
  priority      String?
  assigneeId    String?
  alertId       String            @unique
  completionPct Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  alert         Alert             @relation(fields: [alertId], references: [id], onDelete: Cascade)
  criteria      IASCLCriteria[]
  transitions   IASCLTransition[]
}

model IASCLCriteria {
  id            String      @id @default(uuid())
  text          String
  isMandatory   Boolean     @default(true)
  isMet         Boolean     @default(false)
  iasclActionId String
  iasclAction   IASCLAction @relation(fields: [iasclActionId], references: [id], onDelete: Cascade)
}

model IASCLTransition {
  id            String      @id @default(uuid())
  fromState     String?
  toState       String
  iasclActionId String
  timestamp     DateTime    @default(now())
  iasclAction   IASCLAction @relation(fields: [iasclActionId], references: [id], onDelete: Cascade)
}

model Channel {
  id          String            @id @default(uuid())
  channelType String            @unique
  name        String
  icon        String
  status      String
  apiEndpoint String
  authMethod  String
  canRead     Boolean           @default(true)
  canReply    Boolean           @default(true)
  canDelete   Boolean           @default(false)
  canDM       Boolean           @default(false)
  hasWebhook  Boolean           @default(false)
  instances   ChannelInstance[]
}

model ChannelInstance {
  id          String  @id @default(uuid())
  channelId   String
  label       String
  handle      String
  status      String
  notes       String?
  followers   Int     @default(0)
  totalItems  Int     @default(0)
  pending     Int     @default(0)
  responsePct Float   @default(0)
  channel     Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}
