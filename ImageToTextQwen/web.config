<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Python312\python.exe|C:\Python312\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <appSettings>
      <!-- Path to your Python executable — update if different -->
      <add key="PYTHONPATH" value="C:\inetpub\wwwroot\LivingAI\backend" />
      <add key="WSGI_HANDLER" value="app.app" />
      <add key="WSGI_LOG" value="C:\inetpub\wwwroot\LivingAI\logs\wfastcgi.log" />
    </appSettings>

    <!-- Increase upload size limit for image files (20MB) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>

    <!-- Enable static file serving for frontend assets -->
    <staticContent>
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>

    <rewrite>
      <rules>
        <!-- Serve frontend static files directly -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url="^(.*\.(html|css|js|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf))$" />
          <action type="Rewrite" url="frontend/{R:0}" />
        </rule>
        <!-- Route everything else to Flask -->
        <rule name="FlaskApp" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="backend/app.py/{R:0}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
